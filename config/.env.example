# =============================================================================
# AGENTIC FRAMEWORK — .env
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# ── LLM [REQUIRED] ───────────────────────────────────────────────────────────
# Get from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ── LLM settings ─────────────────────────────────────────────────────────────
# Options: mistral-large-latest | mistral-small-latest | codestral-latest
DEFAULT_MODEL=mistral-large-latest

# ── App settings ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8002
STREAMLIT_PORT=8502
LOG_LEVEL=INFO

# ── MCP base layer ───────────────────────────────────────────────────────────
# Run: npm root -g  → paste the output here
NPM_GLOBAL_ROOT=
# Path to a git repo this agent can operate on
GIT_REPO_PATH=
# Writable workspace folder for filesystem MCP
AGENT_WORKSPACE=/tmp/agent_workspace

# ── Web MCPs ─────────────────────────────────────────────────────────────────
# Firecrawl: https://firecrawl.dev → Dashboard → API Keys
FIRECRAWL_API_KEY=

# ── Dev MCPs ─────────────────────────────────────────────────────────────────
# GitHub: https://github.com/settings/tokens → Classic → scopes: repo, read:org, read:user
GITHUB_TOKEN=

# ── Database MCPs ────────────────────────────────────────────────────────────
SUPABASE_ACCESS_TOKEN=
POSTGRES_URL=

# ── Productivity MCPs ────────────────────────────────────────────────────────
ATLASSIAN_API_TOKEN=
ATLASSIAN_EMAIL=
ATLASSIAN_DOMAIN=
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# ── Business MCPs ────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
AHREFS_API_KEY=

# ── DevOps MCPs ──────────────────────────────────────────────────────────────
KUBECONFIG=
GRAFANA_URL=
GRAFANA_TOKEN=

# ── AI/ML MCPs ───────────────────────────────────────────────────────────────
HF_TOKEN=

# ── Built-in skills ──────────────────────────────────────────────────────────
TAVILY_API_KEY=

# =============================================================================
# MINIMUM TO START:
#   MISTRAL_API_KEY       ← required
#   NPM_GLOBAL_ROOT       ← run: npm root -g
#   GIT_REPO_PATH         ← any git repo path on your machine
#
# One-time npm installs:
#   npm install -g @modelcontextprotocol/server-filesystem
#   npm install -g @modelcontextprotocol/server-memory
#   npm install -g @modelcontextprotocol/server-github
# =============================================================================
